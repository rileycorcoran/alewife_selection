TENDBOTforward1:endTime early() /* exponential growth for p1 (landlocked) */ {
	growthRate1 = asFloat(log(NPOP1/NBOT1)/(TENDBOT1) + 1);
	newSize1 = asInteger(round(growthRate1^(sim.cycle - TENDBOTforward1) * NBOT1));
	p1.setSubpopulationSize(newSize1);
}

TENDBOTforward2:endTime early() /* exponential growth for p2 (landlocked) */ {
	growthRate2 = asFloat(log(NPOP2/NBOT2)/(TENDBOT2) + 1);
	newSize2 = asInteger(round(growthRate2^(sim.cycle - TENDBOTforward2) * NBOT2));
	p2.setSubpopulationSize(newSize2);
}

TENDBOTforward3:endTime early() /* exponential growth for p3 (landlocked) */ {
        growthRate3 = asFloat(log(NPOP3/NBOT3)/(TENDBOT3) + 1);
        newSize3 = asInteger(round(growthRate3^(sim.cycle - TENDBOTforward3) * NBOT3));
        p3.setSubpopulationSize(newSize3);
}

TENDBOTforward4:endTime early() /* exponential growth for p4 (landlocked) */ {
        growthRate4 = asFloat(log(NPOP4/NBOT4)/(TENDBOT4) + 1);
        newSize4 = asInteger(round(growthRate4^(sim.cycle - TENDBOTforward4) * NBOT4));
        p4.setSubpopulationSize(newSize4);
}

// Output the pairwise .vcf files at the end with sample sizes mimicking ming
endTime late() {
	sampleNANC = sample(p0.individuals, out0).haplosomes;
	sampleNPOP1 = sample(p1.individuals, out1).haplosomes;
	sampleNPOP2 = sample(p2.individuals, out2).haplosomes;
        sampleNPOP3 = sample(p3.individuals, out3).haplosomes;
        sampleNPOP4 = sample(p4.individuals, out4).haplosomes;
	c(sampleNANC, sampleNPOP1).outputHaplosomesToVCF(filePath = "OUT_DIR/neutral_vcf_pop1_OUT_SUFFIX.vcf");
	c(sampleNANC, sampleNPOP2).outputHaplosomesToVCF(filePath = "OUT_DIR/neutral_vcf_pop2_OUT_SUFFIX.vcf");
        c(sampleNANC, sampleNPOP3).outputHaplosomesToVCF(filePath = "OUT_DIR/neutral_vcf_pop3_OUT_SUFFIX.vcf");
        c(sampleNANC, sampleNPOP4).outputHaplosomesToVCF(filePath = "OUT_DIR/neutral_vcf_pop4_OUT_SUFFIX.vcf");
}
